# ─── MongoDB Configuration ───────────────────────────────────────
# REQUIRED: Replace with your MongoDB Atlas connection string
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/gayatri_school?retryWrites=true&w=majority

# ─── Flask Configuration ────────────────────────────────────────
# REQUIRED: Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE-THIS-generate-a-64-char-hex-string
FLASK_ENV=production

# ─── Email Configuration ────────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com

# ─── Session Security ───────────────────────────────────────────
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
SESSION_TIMEOUT_HOURS=1

# ─── Rate Limiting ──────────────────────────────────────────────
RATELIMIT_ENABLED=True
RATELIMIT_STORAGE_URL=memory://

# ─── File Upload Settings ───────────────────────────────────────
MAX_CONTENT_LENGTH=2097152
UPLOAD_FOLDER=static/uploads

# ─── Default Account Credentials ────────────────────────────────
# IMPORTANT: Change these immediately after first deployment!
ADMIN_USERNAME=GVP022026
ADMIN_DEFAULT_PASSWORD=CHANGE_THIS_PASSWORD_IMMEDIATELY
PRINCIPAL_USERNAME=principal
PRINCIPAL_DEFAULT_PASSWORD=CHANGE_THIS_PASSWORD_IMMEDIATELY
ACCOUNTANT_USERNAME=accountant
ACCOUNTANT_DEFAULT_PASSWORD=CHANGE_THIS_PASSWORD_IMMEDIATELY
DEFAULT_TEACHER_PASSWORD=GVP@2026

# ─── Logging ────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/school_app.log

# ─── OTP Settings ───────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=3

# ─── Login Security ─────────────────────────────────────────────
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
