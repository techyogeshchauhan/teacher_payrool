__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# ─── Virtual Environment ─────────────────────────────────────────
venv/
.venv/
env/

# ─── Logs ────────────────────────────────────────────────────────
logs/
*.log

# ─── Flask Session Files ─────────────────────────────────────────
flask_session/

